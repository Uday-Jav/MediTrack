PORT=5000
NODE_ENV=development

# Comma-separated allowed frontend origins
CORS_ORIGIN=http://localhost:5173

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini
MOCK_OPENAI_RESPONSE=false

# PostgreSQL (either DATABASE_URL or explicit fields)
DATABASE_URL=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=medivault
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_SSL=false
POSTGRES_SSL_REJECT_UNAUTHORIZED=false
POSTGRES_POOL_MAX=10
POSTGRES_IDLE_TIMEOUT_MS=30000
POSTGRES_CONN_TIMEOUT_MS=10000
POSTGRES_FALLBACK_MEMORY=false

# Existing auth/record routes still use JWT + Mongo (optional for chatbot-only usage)
JWT_SECRET=your_jwt_secret
MONGODB_URI=
MONGODB_DB_NAME=medivault

# Rate limiting
API_RATE_LIMIT_MAX=300
CHAT_RATE_LIMIT_MAX=60
TRANSLATION_RATE_LIMIT_MAX=120
